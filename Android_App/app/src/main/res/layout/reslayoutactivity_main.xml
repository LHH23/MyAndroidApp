<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- 顶部状态文字 -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="8dp"
        android:text="正在连接…"
        android:textColor="#4CAF50"
        android:textSize="12sp"
        android:textStyle="bold"
        android:background="@drawable/bg_rounded_transparent"
        android:layout_marginBottom="4dp"/>

    <!-- 免责声明小字 -->
    <TextView
        android:id="@+id/tv_small_disclaimer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="#AA000000"
        android:textSize="10sp"
        android:paddingBottom="4dp"/>

    <!-- 注意事项固定栏 -->
    <TextView
        android:id="@+id/tv_notice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:textColor="#88000000"
        android:textSize="11sp"
        android:lineSpacingExtra="2dp"
        android:padding="8dp"
        android:background="@drawable/bg_rounded_transparent"
        android:layout_marginBottom="8dp"/>

    <!-- 知识列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_knowledge"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp"/>

    <!-- 底部操作区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="@drawable/bg_rounded_transparent_darker"
        android:layout_marginTop="8dp">

        <EditText
            android:id="@+id/et_author"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:hint="昵称（选填，最多7字）"
            android:maxLength="7"
            android:textSize="14sp"
            android:paddingHorizontal="12dp"
            android:background="@android:color/white"
            android:layout_marginBottom="6dp"
            android:inputType="text"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/et_content"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="输入知识…（100字内）"
                android:maxLength="100"
                android:textSize="14sp"
                android:paddingHorizontal="12dp"
                android:background="@android:color/white"
                android:inputType="text"/>

            <Button
                android:id="@+id/btn_publish"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="发布"
                style="@style/IOSButton"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_refresh"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="刷新"
                style="@style/IOSButton"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_sponsor"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="赞助"
                style="@style/IOSButton"
                android:layout_marginStart="4dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>