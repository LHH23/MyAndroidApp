<resources>
    <style name="IOSButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_rounded_transparent</item>
        <item name="android:textColor">#007AFF</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="SponsorDialogTheme" parent="Theme.AppCompat.Light.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>
</resources>